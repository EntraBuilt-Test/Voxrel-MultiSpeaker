{
  "name": "kreactive-backend",
  "version": "1.0.0",
  "description": "A high-performance, role-based backend for a task-management platform.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "npm run build:clean && tsc && tsc-alias",
    "build:clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\" \"!node_modules/**\" \"!dist/**\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json}\" \"!node_modules/**\" \"!dist/**\"",
    "type-check": "tsc --noEmit",
    "code:check": "npm run type-check && npm run lint && npm run format:check",
    "code:fix": "npm run type-check && npm run lint:fix && npm run format",
    "seed:credentials": "tsx scripts/seed-credentials.ts",
    "clean:db": "tsx clean_database.ts",
    "migrate:mongodb": "tsx migrate_mongodb.ts",
    "check:users": "tsx check_users.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.525.0",
    "@aws-sdk/lib-storage": "^3.921.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@upstash/redis": "^1.28.4",
    "aws-sdk": "^2.1692.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.0",
    "mock-aws-s3": "^4.0.2",
    "mongodb": "^6.3.0",
    "mongoose": "^8.2.1",
    "multer": "1.4.5-lts.1",
    "nock": "^14.0.10",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.4.2",
    "uuid": "^13.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/eslint__js": "^9.14.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.25",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@typescript-eslint/parser": "^8.44.1",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "esno": "^0.16.3",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "tsx": "^4.7.0",
    "typescript-eslint": "^8.44.1"
  },
  "author": "Jules",
  "license": "ISC",
  "overrides": {
    "iconv-lite": "0.6.3"
  }
}
